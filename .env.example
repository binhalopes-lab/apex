# ============================================================
# APEX Performance System — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Banco de dados (Supabase)
# Formato: postgresql://postgres:[SENHA]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# Segredo para assinar os cookies de sessão (qualquer string longa e aleatória)
JWT_SECRET=

# ID do app no Manus (sistema de autenticação)
# Se não usar o OAuth do Manus, pode deixar em branco por enquanto
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Ambiente
NODE_ENV=production
